   "source": [
    "#| label: yates-fpr\n",
    "#| code-fold: true\n",
    "#| fig-align: center\n",
    "\n",
    "sizes = np.arange(4, 40, 3)\n",
    "with_y  = [chi2_rejection_rate(n, 0.3, 0.3, correction=True)  for n in sizes]\n",
    "no_y    = [chi2_rejection_rate(n, 0.3, 0.3, correction=False) for n in sizes]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 4.4))\n",
    "ax.plot(sizes, [r for r, _ in with_y], color=red_pink, lw=2.5, marker=\"o\",\n",
    "        label=\"with Yates\")\n",
    "ax.fill_between(sizes, [ci[0] for _, ci in with_y], [ci[1] for _, ci in with_y],\n",
    "                color=red_pink, alpha=0.15)\n",
    "ax.plot(sizes, [r for r, _ in no_y], color=blue, lw=2.5, ls=\"--\", marker=\"s\",\n",
    "        label=\"no correction\")\n",
    "ax.fill_between(sizes, [ci[0] for _, ci in no_y], [ci[1] for _, ci in no_y],\n",
    "                color=blue, alpha=0.12)\n",
    "ax.axhline(0.05, color=orange, ls=\":\", lw=2, label=r\"$\\alpha = 0.05$\")\n",
    "ax.set_xlabel(\"group size n\"); ax.set_ylabel(\"FPR\")\n",
    "ax.set_title(\"FPR vs sample size (H0 true)\"); ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
