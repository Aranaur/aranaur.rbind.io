   "source": [
    "#| label: gof-mc-fn\n",
    "\n",
    "def gof_rejection_rate(p_true, p_null, n, n_exps=2000,\n",
    "                       alpha=0.05, seed=1):\n",
    "    \"\"\"Goodness-of-fit chi-square via Monte Carlo.\n",
    "\n",
    "    p_true == p_null -> H0 true  -> the rate is the FPR.\n",
    "    p_true != p_null -> H1 true  -> the rate is the power.\n",
    "    \"\"\"\n",
    "    rng, rej = np.random.default_rng(seed), 0\n",
    "    p_null = np.asarray(p_null)\n",
    "    for _ in range(n_exps):\n",
    "        counts = rng.multinomial(n, p_true)\n",
    "        rej += chisquare(counts, f_exp=n * p_null).pvalue <= alpha\n",
    "    ci = proportion_confint(rej, n_exps, alpha=0.05, method=\"wilson\")\n",
    "    return rej / n_exps, ci\n",
    "\n",
    "uniform = np.full(6, 1 / 6)\n",
    "fpr, ci = gof_rejection_rate(uniform, uniform, n=60)\n",
    "print(f\"FPR (fair die, n=60): {fpr:.3f}\")\n",
    "print(f\"95% CI: ({ci[0]:.3f}, {ci[1]:.3f})\")"
   ]
  },
