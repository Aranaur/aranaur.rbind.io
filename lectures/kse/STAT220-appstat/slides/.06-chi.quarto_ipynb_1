    "#| label: chi2-distribution\n",
    "#| code-fold: true\n",
    "#| fig-align: center\n",
    "\n",
    "x = np.linspace(0.001, 15, 1000)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 4.6))\n",
    "for df, c in [(1, red_pink), (2, blue), (3, slate), (5, green), (10, orange)]:\n",
    "    ax.plot(x, chi2.pdf(x, df=df), color=c, lw=2.2, label=f\"df = {df}\")\n",
    "ax.set_ylim(0, 0.5)\n",
    "ax.set_title(r\"$\\chi^2$ probability density\"); ax.set_xlabel(\"x\"); ax.set_ylabel(\"density\")\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
