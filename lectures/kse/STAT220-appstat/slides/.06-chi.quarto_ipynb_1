   "source": [
    "#| label: fisher\n",
    "\n",
    "table_2x2 = np.array([[15, 18], [15, 13]])\n",
    "\n",
    "odds, p_fisher = fisher_exact(table_2x2)\n",
    "p_yates = chi2_contingency(table_2x2)[1]\n",
    "\n",
    "print(f\"Fisher odds ratio = {odds:.3f}\")\n",
    "print(f\"Fisher p-value    = {p_fisher:.4f}\")\n",
    "print(f\"Yates  p-value    = {p_yates:.4f}\")"
   ]
