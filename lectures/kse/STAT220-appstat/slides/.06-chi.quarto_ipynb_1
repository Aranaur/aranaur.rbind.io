   "source": [
    "#| label: yates-power\n",
    "#| code-fold: true\n",
    "#| fig-align: center\n",
    "\n",
    "sizes = np.arange(50, 2001, 250)\n",
    "with_y = [chi2_rejection_rate(n, 0.30, 0.35, correction=True)  for n in sizes]\n",
    "no_y   = [chi2_rejection_rate(n, 0.30, 0.35, correction=False) for n in sizes]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 4.4))\n",
    "ax.plot(sizes, [r for r, _ in with_y], color=purple, lw=2.5, marker=\"o\",\n",
    "        label=\"with Yates\")\n",
    "ax.plot(sizes, [r for r, _ in no_y], color=blue, lw=2.5, ls=\"--\", marker=\"s\",\n",
    "        label=\"no correction\")\n",
    "ax.axhline(0.8, color=slate, ls=\":\", lw=2, label=\"80% gold standard\")\n",
    "ax.set_ylim(0, 1)\n",
    "ax.set_xlabel(\"group size n\"); ax.set_ylabel(\"power (TPR)\")\n",
    "ax.set_title(\"Power vs sample size (H1 true)\"); ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
