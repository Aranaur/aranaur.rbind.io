   "cell_type": "code",
   "execution_count": 14,
   "id": "chi2-mc-fn",
   "metadata": {},
   "outputs": [],
   "source": [
    "#| label: chi2-mc-fn\n",
    "\n",
    "def chi2_rejection_rate(n, p1, p2, correction, alpha=0.05,\n",
    "                        n_exps=3000, seed=42):\n",
    "    \"\"\"2x2 chi-square homogeneity test via Monte Carlo.\n",
    "\n",
    "    p1 == p2  -> H0 true  -> the rate is the FPR.\n",
    "    p1 != p2  -> H1 true  -> the rate is the power (TPR).\n",
    "    \"\"\"\n",
    "    rng, rej = np.random.default_rng(seed), 0\n",
    "    for _ in range(n_exps):\n",
    "        a = binom.rvs(n, p1, random_state=rng); b = n - a   # group 1\n",
    "        c = binom.rvs(n, p2, random_state=rng); d = n - c   # group 2\n",
    "        if (a + c) and (b + d):                             # avoid empty column\n",
    "            p = chi2_contingency([[a, b], [c, d]],\n",
    "                                 correction=correction)[1]\n",
    "        else:\n",
    "            p = 1.0\n",
    "        rej += p <= alpha\n",
    "    ci = proportion_confint(rej, n_exps, alpha=0.05, method=\"wilson\")\n",
    "    return rej / n_exps, ci"
   ]
  },
