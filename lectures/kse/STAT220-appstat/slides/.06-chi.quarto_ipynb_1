    "#| label: die-observed-expected\n",
    "#| code-fold: true\n",
    "#| fig-align: center\n",
    "\n",
    "faces    = np.arange(1, 7)\n",
    "observed = np.array([5, 8, 9, 8, 10, 20])\n",
    "n        = observed.sum()\n",
    "expected = np.full(6, n / 6)            # 10 per face under H0\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4.2))\n",
    "ax.bar(faces - 0.18, observed, width=0.36, color=red_pink, label=\"observed $O$\")\n",
    "ax.bar(faces + 0.18, expected, width=0.36, color=slate,   label=\"expected $E$\")\n",
    "ax.set_title(\"A die rolled 60 times\"); ax.set_xlabel(\"face\"); ax.set_ylabel(\"count\")\n",
    "ax.set_xticks(faces); ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
