    "#| label: cramers-v\n",
    "\n",
    "chi2_stat, p, dof, _ = chi2_contingency(table)\n",
    "n = table.sum()\n",
    "V = np.sqrt(chi2_stat / (n * (min(table.shape) - 1)))\n",
    "\n",
    "print(f\"chi2     = {chi2_stat:,.0f}\")\n",
    "print(f\"p-value  = {p:.1g}\")\n",
    "print(f\"n        = {n:,}\")\n",
    "print(f\"Cramer V = {V:.3f}\")"
   ]
