   "source": [
    "#| label: die-chisquare\n",
    "\n",
    "# chisquare() compares observed counts to a uniform expectation by default\n",
    "res = chisquare(observed)\n",
    "k   = len(observed)\n",
    "\n",
    "print(f\"chi2      = {res.statistic:.2f}\")\n",
    "print(f\"df        = {k - 1}\")\n",
    "print(f\"p-value   = {res.pvalue:.4f}\")\n",
    "print(\"reject H0\" if res.pvalue < 0.05\n",
    "      else \"keep H0\")"
   ]
